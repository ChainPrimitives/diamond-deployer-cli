{
  "name": "diamond-deployer-cli",
  "version": "1.0.0",
  "description": "CLI for deploying, upgrading, and verifying EIP-2535 Diamond proxy contracts",
  "license": "MIT",
  "author": "Subaskar Sivakumar <subaskar@github.com> (https://github.com/Subaskar-S)",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChainPrimitives/diamond-deployer-cli"
  },
  "keywords": [
    "diamond",
    "eip-2535",
    "cli",
    "deploy",
    "solidity",
    "proxy",
    "upgrade",
    "ethereum",
    "blockchain"
  ],
  "bin": {
    "diamond": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "dist",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ethers": "^6.11.0",
    "fs-extra": "^11.2.0",
    "ora": "^8.0.1",
    "yaml": "^2.4.1"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^1.3.0",
    "rimraf": "^5.0.5",
    "tsup": "^8.0.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.3.0"
  }
}
